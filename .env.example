# Order: (1) Create Pinecone index in console/CLI  (2) Fill keys below + PINECONE_INDEX name
#         (3) npm run dev → copy workspace id  (4) npm run laws:pipeline -- <that-id>
#
# --- Neon Postgres (auth, feedback, rate limits) ---
# Create a database in Neon (Console or Cursor Neon MCP), then:
#   npm run db:push
DATABASE_URL=
# At least 32 random characters (JWT signing)
AUTH_JWT_SECRET=
# Per-user limits (UTC buckets): chat = per hour, feedback = per day
MASHREQ_RATE_CHAT_PER_HOUR=60
MASHREQ_RATE_FEEDBACK_PER_DAY=10
# Grant admin: npm run db:grant-admin -- 2499xxxxxxxx

# --- Vector mode (required behavior) ---
# integrated = Pinecone embeds text (upsertRecords / searchRecords). Index needs integrated model + text=content.
# byov        = Bring-your-own vectors via LangChain + Together (default if unset).
MASHREQ_VECTOR_MODE=byov

PINECONE_API_KEY=
PINECONE_INDEX=mashreq-vectors

# Optional: single shared Pinecone namespace for **all** users (chat + ingest).
# When set, the server ignores per-request `namespaceId` and uses this value.
# Ingest once (e.g. `npm run laws:pipeline -- legal`) and use the same id here:
# MASHREQ_RAG_NAMESPACE=legal

# --- BYOV only (MASHREQ_VECTOR_MODE=byov) ---
# Together AI — embeddings for LangChain PineconeStore
# https://api.together.xyz/
TOGETHER_AI_API_KEY=
TOGETHER_EMBEDDING_MODEL=togethercomputer/m2-bert-80M-8k-retrieval

# --- Integrated only ---
# npm run pinecone:create-integrated-index -- mashreq-legal
# Or CLI (pc v0.3+): dimension 1024 for llama-text-embed-v2
# pc index create --name mashreq-legal --dimension 1024 --metric cosine --cloud aws --region us-east-1 --model llama-text-embed-v2 --field-map text=content
# Then: MASHREQ_VECTOR_MODE=integrated  PINECONE_INDEX=mashreq-legal

# Groq — chat LLM
# https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional: default metadata.category for bulk PDF/processed ingest
# MASHREQ_DEFAULT_LAW_CATEGORY=قانون سوداني

# Optional: force pdf.js layout-aware text extraction for all PDFs (slower; helps glued Arabic)
# MASHREQ_PDF_LAYOUT_EXTRACT=1

# Optional: never use pdf.js layout pass (only pdf-parse + refine). Use if layout adds bad breaks.
# MASHREQ_PDF_PARSE_ONLY=1

# pdf.js only: sort text runs on each line by x for RTL Arabic (matches viewer copy order). Set 0 to disable.
# MASHREQ_PDF_JS_RTL_LINE_SORT=0

# Optional: reverse word order on Arabic-heavy lines with no ASCII digits (e.g. الفصل الأول); skips lines with years/clause numbers
# MASHREQ_PDF_AR_REV_WORDS=1

# Spurious in-word spaces from PDFs are merged by default; set to 0 to disable
# MASHREQ_PDF_AR_MERGE_FRAGMENTS=0

# PDFs in laws/ → same pipeline as step (4) in the header comment above
